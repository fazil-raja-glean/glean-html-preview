{
  "name": "html-sharing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && vitest run",
    "test": "vitest run",
    "dev": "npm run dev:local",
    "dev:local": "wrangler dev --config wrangler.local.toml",
    "dev:public": "wrangler dev",
    "deploy": "npm run deploy:local",
    "deploy:local": "npm run deploy:preview:local && npm run deploy:api:local && npm run deploy:mcp:local",
    "deploy:preview:local": "wrangler deploy --config wrangler.local.toml --env=\"\"",
    "deploy:api:local": "wrangler deploy --config wrangler.local.toml --env api",
    "deploy:mcp:local": "wrangler deploy --config wrangler.local.toml --env mcp",
    "deploy:dry-run": "wrangler deploy --env=\"\" --dry-run && wrangler deploy --env api --dry-run && wrangler deploy --env mcp --dry-run",
    "deploy:dry-run:local": "npm run deploy:preview:local -- --dry-run && npm run deploy:api:local -- --dry-run && npm run deploy:mcp:local -- --dry-run",
    "config:init:local": "test -f wrangler.local.toml || cp wrangler.toml wrangler.local.toml",
    "setup:agent": "node scripts/setup-agent.mjs",
    "verify:config": "node scripts/verify-config.mjs",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "d1:migrate:local": "node scripts/apply-d1-schema.mjs local",
    "d1:migrate:dev": "node scripts/apply-d1-schema.mjs dev",
    "d1:migrate:prod": "node scripts/apply-d1-schema.mjs prod"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.102.0"
  }
}
